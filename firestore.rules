rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Explicit matches for all collections used in the app
    match /clients/{id} { allow read, write: if true; }
    match /projects/{id} { allow read, write: if true; }
    match /budgets/{id} { allow read, write: if true; }
    match /contracts/{id} { allow read, write: if true; }
    match /vendors/{id} { allow read, write: if true; }
    match /admins/{id} { allow read, write: if true; }
    match /house_models/{id} { allow read, write: if true; }
    match /test/{id} { allow read, write: if true; }
    
    // Global safety net for any other paths
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
